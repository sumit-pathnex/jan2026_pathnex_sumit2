    agent any
    environment {
        INSTITUTE_NAME = "sumit"
    }
    stages {
        stage('build')
	    steps {
	        sh 'mvn clean package'
            }
        }
	stage('promote') {
	    steps {
	        sh 'mvn clean package'
	    }
	}
    }
}

