## kubernetes - self healing with liveness and readiness probe

apiVersion: apps/v1
kind: deployment
metadata:
  name: sumit-web-app
spec:
  replicas: 3
  selector
    matchLabels:
      app: pathnex-web-app
  template:
    metadata:
      labels:
        app: sumit-app
  spec:
    containers:
      - name: nginx
      ports:
        - containerport: 80
      livenessprobe:
        httpGet:
	  path: /healthz
	  port: 80
	initialDelaysecond: 5
	periodSeconds: 10
      readinessProbe:
        httpGet:
	  path: /health
	  port: 80
	initialDelaySecond: 5
	periodsecond: 10


