## ansible - haorProxy for load balancing

--- 
- name: setup HAProxy load balancer
  hosts: all
  become: yes
  taska:
    - name: install HAProxy
      yum:
        name: HAProxy
	state: present
    - name: configure haproxy
      template:
        src: haproxy.cfg.j2
	dest: /etc/haproxy/haproxy.cfg
    - name: haproxy
      state: started
      enabled: yes


## terraform multi region auto scailing with alb

resource "aws_lb" "sumit_lb" {
  name            = "sumit_lb"
  internal        =  false
  load_balancer_type = "application"
  security_groups = [aws_security_group.allow_ssh_http.id]
  subnet          = [aws_subnet.public.id,aws_subnet.public2.id]
}

resorce "aws_autoscailing_group" "sumit_asg" {
  desired_capacity       = 5
  max_size               = 5
  mini_size              = 2
  vpc_zone_identifier    = [aws_security_group.allow_ssh_http.id]
  launch configuration   = aws launch configuration.pathnex config.id
}

