## day 19 advanced monitering logging security
## ansible setuo for prometheus monitering

- name: install prometheus for monitering
  hosts: all
  become: yes
  tasks:  
    - name: install prometheus
      yum:
        name: 
	  -  prometheus
          -  prometheus-node -exporter
	state: present
    - name: start prometheus
      service:
        name: prometheus
	state: started
	enabled: yes


