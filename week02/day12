## kubernetes - rolling update strategy

apiVersion: app/v1
kind: deployment
metadata:
  name: sumit-rolling
spec:
  replicas: 3
  strategy:
    type: rollingupdate
      maxSurge: 1
      maxUnavailable: 1
selector:
  matchLabels:
  app: roll
template:
  metadata:
    labels:
      app: roll
spec:
  containers:
  - name: web
    image: nginx


## shell script - backup directory

#!/bin/bash

SOURCE= "/var/log"
DEST="/backup/pathnex-$(date =%F).tar.gz"

tar -czf $DEST $SOURCE
echo"backup created at: $DEST"

# multi-branch pipeline

## jenkins pipeline - multi branch


pipeline {
    agent any
    environment
        INSTITUTE_NAME = "sumit"
    }
    stages {
        stage('checkout') {
            steps {
                checkout scm
            }
        }
        stage('build') {
            steps {
                sh 'mvn clean compile'
            }
        }
    }
}

