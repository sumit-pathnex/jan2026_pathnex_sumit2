pipeline {
    agent any
    environment {
        INSTITUTE_NAME = "sumit devops training"
    }
    stages {
        stage('checkout') {
            steps {
                sh 'mvn clean package'
            }
        }
    }
    post {
        success {
            mail to: gautambari8826@gmail.com
            subject: "successful build"
            body: "build is successful for ${sumit devops training}"
        }
        failure {
            mail to: gautambari8826@gmail.com
                 subject:build failed
                 body: build is failed for ${sumit devops training}
