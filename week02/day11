ansible install maria db

---
- name: install mariadb for sumit
  hosts: all
  becom: yes

  tasks:
    - name: install mariadb
      yum:
        name: mariadb-server
        state: present

    - name: start mariabd
      service:
        name: mariadb
        state: started
        enabled: yes

