## ansible setup nginx with reserve proxy

---
- name: setup nginx with reserve proxy
  hosts: all
  become: yes
  tasks:
    - name: install nginx
      yum:
        name: nginx
        state: present
    - name: configure nginx as reserve proxy
      template:
        src: reserve-proxy.conf.j2
	dest: /etc/nginx/conf.d/reserve-proxy.conf
    - name: restsrt nginx service
      sevice:
        name: nginx
	state: started
	enabled: yes


## terraform create s3 bucket with versioning and loggin
resource "aws_s3_bucket" {
  bucket = "sumit" 
  versioning {
    enabled = true
  }

  logging {
    target_bucket = "sumit-log-bucket"
    target_prefix = "logs/"
  }
}

kubernetes ingress with nginx controller

apiVersion = networking.k8s.io/v1
kind: ingress
metadata:
  name: sumit-ingress
  annotation:
    nginx.ingress.kubernetes.io/rewrites-target: /
  spec:
    rules: 
      - host: sumit.local
        http:
	  paths:
	  - path: /
	    pathType: prefix
	    backend:
	      service:
	        name: pathnex-service
		port:
		  number: 80


